                />

                <!-- Center hub -->
                <lv_obj
                    x="140"
                    y="140"
                    width="200"
                    height="200"
                    style_radius="100"
                    style_bg_color="0x000000"
                    style_border_width="1"
                    style_border_color="0x595959"
                    style_pad_all="0"
                >
                    <lv_label align="center" y="-26" text="72" style_text_color="0xFFFFFF" />
                    <lv_label align="center" y="22" text="mph" style_text_color="0xE6E6E6" />
                </lv_obj>

                <!-- Fuel icon + text placeholder -->
                <lv_label x="218" y="392" text="FUEL" style_text_color="0xB0B0B0" />
                <lv_label x="222" y="414" text="67%" style_text_color="0xFFFFFF" />
            </lv_obj>
        </lv_obj>
    </view>
