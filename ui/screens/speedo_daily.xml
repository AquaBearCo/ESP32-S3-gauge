                />

                <!-- Fuel arc (outer indicator) -->
                <lv_arc
                    x="17"
                    y="17"
                    width="446"
                    height="446"
                    rotation="65"
                    style_arc_width="4"
                    style_arc_color="0x8A8A8A"
