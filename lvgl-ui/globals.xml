    <styles>
        <style name="bg_root" bg_color="0x06090F"/>
        <style name="bg_panel" bg_color="0x101722" radius="#panel_radius"/>
        <style name="txt_primary" text_color="0xE8EEF5"/>
        <style name="txt_muted" text_color="0x89A0B8"/>
    </styles>
</globals>
